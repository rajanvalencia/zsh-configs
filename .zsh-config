# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Keep PATH entries unique — drops duplicates that tools prepend on each
# shell start (node, bun, go, herd, etc.) and dedupes the existing PATH.
typeset -U path PATH

# syntax highlighting extension
source "${HOME}/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# auto suggestion
source "${HOME}/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"

# powerlevel10k
source "${HOME}/.zsh/powerlevel10k/powerlevel10k.zsh-theme"

# starship init
eval "$(starship init zsh)"

# eza (modern ls) — Dracula theme lives in ~/.config/eza/theme.yml
export EZA_CONFIG_DIR="${HOME}/.config/eza"

alias ls="eza -a --icons --tree --level=1"
alias cat="bat --theme=Dracula"

# ---------------------------------------------------------------------------
# Dev environment (each block no-ops when the tool is not installed)
# ---------------------------------------------------------------------------

# nvm (Node Version Manager)
export NVM_DIR="${HOME}/.nvm"
if command -v brew >/dev/null 2>&1; then
  _nvm_prefix="$(brew --prefix nvm 2>/dev/null)"
  [ -s "${_nvm_prefix}/nvm.sh" ] && source "${_nvm_prefix}/nvm.sh"
  [ -s "${_nvm_prefix}/etc/bash_completion.d/nvm" ] && source "${_nvm_prefix}/etc/bash_completion.d/nvm"
  unset _nvm_prefix
fi

# gvm (Go Version Manager)
[[ -s "${HOME}/.gvm/scripts/gvm" ]] && source "${HOME}/.gvm/scripts/gvm"

# php-version (PHP Version Manager)
[ -s "${HOME}/.php-version/php-version.sh" ] && source "${HOME}/.php-version/php-version.sh"

# Go binaries, Composer global binaries (Laravel installer, etc.)
export PATH="${HOME}/go/bin:${HOME}/.composer/vendor/bin:${HOME}/.config/composer/vendor/bin:${PATH}"

# Laravel Herd shims (placed last so Herd's PHP takes precedence when present)
[ -d "${HOME}/Library/Application Support/Herd/bin" ] && export PATH="${HOME}/Library/Application Support/Herd/bin:${PATH}"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
